# LLM: DashScope (通义千问) via OpenAI-compatible API
# 填入你的百炼 API Key: https://bailian.console.aliyun.com
# 本地开发：复制本文件为 .env.local 后填写真实密钥，不要直接提交真实密钥。
# 生产环境：使用 npx wrangler secret put 或 Cloudflare Dashboard 注入密钥。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.6-max-preview
